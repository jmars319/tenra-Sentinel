{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sentinel by Tenra",
  "version": "0.1.0",
  "identifier": "co.tenra.sentinel.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @sentinel/desktopapp run dev",
    "beforeBuildCommand": "pnpm --filter @sentinel/desktopapp run build:ui",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sentinel by Tenra",
        "width": 1320,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
