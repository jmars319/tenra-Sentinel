{
  "name": "@sentinel/mobileapp",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "export": "expo export --platform ios --platform android --output-dir dist"
  },
  "dependencies": {
    "@sentinel/config": "workspace:*",
    "expo": "^53.0.0",
    "expo-status-bar": "~2.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "0.79.0",
    "react-native-web": "^0.20.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "babel-preset-expo": "^13.0.0",
    "typescript": "^5.8.2"
  }
}
